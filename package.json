{
  "name": "@wsopcua/wsopcua",
  "version": "0.9.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Michael Derfler",
  "private": false,
  "main": "dist/_cjs/index.js",
  "jsnext:main": "dist/_esm/index.js",
  "es2015": "dist/_esm/index.js",
  "module": "dist/_esm/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/demike/wsopcua.git"
  },
  "dependencies": {
    "async": "^3.2.3",
    "loglevel": "^1.8.0",
    "setimmediate": "^1.0.5"
  },
  "devDependencies": {
    "@types/async": "^3.2.12",
    "@types/loglevel": "^1.6.3",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@vitest/utils": "^4.1.4",
    "chalk": "^4.1.2",
    "eslint": "^8.9.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-webpack-plugin": "^3.1.1",
    "happy-dom": "^13.3.0",
    "jsdom": "^24.0.0",
    "prettier": "^2.5.1",
    "start-server-and-test": "^1.14.0",
    "ts-loader": "^9.2.6",
    "typescript": "^5.2.2",
    "vitest": "^4.1.4",
    "wsopcua-test-server": "^1.6.2"
  },
  "scripts": {
    "postinstall": "cd src/schema_parser && npm install",
    "compile": "tsc -b ./src/tsconfig.cjs.json ./src/tsconfig.esm.json  ./src/tsconfig.types.json",
    "package:prepare": "npm run compile && npm run build-min --prefix src/schema_parser && node ./tools/prepare-package.js && node ./tools/generate-alias",
    "build": "tsc -p ./src/tsconfig.esm.json",
    "watch": "tsc -p ./src/tsconfig.esm.json --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:ci": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "test-server": "wsopcua-test-server",
    "e2e:run": "start-server-and-test test-server tcp:4444 \"vitest run --browser --config vitest.e2e.config.ts\"",
    "e2e:watch": "start-server-and-test test-server tcp:4444 \"vitest --browser --config vitest.e2e.config.ts\"",
    "e2e:ci": "start-server-and-test test-server tcp:4444 \"vitest run --browser --browser.headless --config vitest.e2e.config.ts\"",
    "lint": "eslint -c .eslintrc.js --ignore-pattern \"**/*.d.ts\" --ext .ts src",
    "format:all": "prettier --write \"src/**/*.ts\""
  },
  "files": [
    "documentation/**/*",
    "dist/**/*",
    "!dist/**/*.spec.*",
    "!dist/**/*.e2e-spec.*",
    "src/schema_parser/dist/wsopcua-schema-gen.js",
    "src/schema_parser/schemas/**/*",
    "!src/examples/**/*"
  ]
}